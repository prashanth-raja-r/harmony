# ─── Database ────────────────────────────────────────────────────────────────
# Railway provides DATABASE_URL automatically when you add a PostgreSQL service.
# Copy the "DATABASE_URL" value from the Railway PostgreSQL Variables tab.
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_SSL=true

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=https://your-app.up.railway.app

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_EXPIRES_IN=7d

# ─── AI Coach ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email / SMTP ────────────────────────────────────────────────────────────
# Gmail: enable 2FA → generate App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=Harmony Finance <you@gmail.com>
